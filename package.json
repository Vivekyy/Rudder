{
  "name": "@vivekyy/rudder",
  "version": "1.1.0",
  "description": "A local-first desktop app for AI coding prompts, stats, and daily digests.",
  "private": true,
  "desktopName": "Rudder",
  "type": "module",
  "main": "dist/electron/main.js",
  "engines": {
    "node": ">=23.6.0"
  },
  "files": [
    "dist",
    "out",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "claude",
    "claude-code",
    "codex",
    "prompts",
    "digest",
    "electron",
    "nextjs",
    "productivity",
    "developer-tools"
  ],
  "author": "Vivek Yanamadula <vivek@archermoney.com>",
  "license": "MIT",
  "homepage": "https://github.com/Vivekyy/Rudder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vivekyy/Rudder.git"
  },
  "bugs": {
    "url": "https://github.com/Vivekyy/Rudder/issues"
  },
  "scripts": {
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write --error-on-warnings .",
    "typecheck": "tsc --noEmit",
    "build:main": "rm -rf dist && tsc -p tsconfig.build.json",
    "build:renderer": "next build",
    "build": "rm -rf dist out .next && npm run build:main && npm run build:renderer",
    "dev:renderer": "next dev",
    "dev:electron": "npm run build:main && RUDDER_RENDERER_URL=http://localhost:3000 electron dist/electron/main.js",
    "package": "npm run build && electron-builder",
    "test": "node --test test/*.ts",
    "check": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "build": {
    "appId": "com.vivekyy.rudder",
    "productName": "Rudder",
    "executableName": "rudder",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "out/**/*",
      "package.json",
      "LICENSE",
      "README.md"
    ],
    "extraMetadata": {
      "main": "dist/electron/main.js"
    },
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "syncDesktopName": true
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "fix-path": "^5.0.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shell-quote": "^1.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/shell-quote": "^1.7.5",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "node": "^26.3.1",
    "typescript": "^5.7.0"
  }
}
