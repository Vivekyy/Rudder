{
  "name": "@ruddercode/rudder-core",
  "version": "0.2.1",
  "description": "Clean infrastructure baseline for the Rudder rebuild.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "rudder-prompt-hook": "./dist/bin/rudder-prompt-hook.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "engines": {
    "node": ">=23.6.0"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "claude",
    "claude-code",
    "codex",
    "prompts",
    "cli",
    "productivity",
    "developer-tools"
  ],
  "author": "Vivek Yanamadula <vivek@archermoney.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Vivekyy/Rudder#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vivekyy/Rudder.git"
  },
  "bugs": {
    "url": "https://github.com/Vivekyy/Rudder/issues"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod +x dist/bin/rudder-prompt-hook.js && cp -R drizzle dist/drizzle",
    "test": "node --test",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "drizzle-orm": "1.0.0-rc.4",
    "posthog-node": "^5.41.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "drizzle-kit": "1.0.0-rc.4",
    "typescript": "^5.7.0"
  }
}
