{
  "name": "@ruddercode/rudder-core",
  "version": "0.2.1",
  "description": "Record Claude Code and Codex prompts and learn durable rules from corrections.",
  "type": "module",
  "bin": {
    "rudder": "dist/bin/rudder.js"
  },
  "engines": {
    "node": ">=23.6.0"
  },
  "files": [
    "dist",
    "assets",
    "drizzle",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "claude",
    "claude-code",
    "codex",
    "prompts",
    "cli",
    "productivity",
    "developer-tools"
  ],
  "author": "Vivek Yanamadula <vivek@archermoney.com>",
  "license": "MIT",
  "homepage": "https://github.com/Vivekyy/Rudder#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vivekyy/Rudder.git"
  },
  "bugs": {
    "url": "https://github.com/Vivekyy/Rudder/issues"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit && tsc -p frontend/tsconfig.json --noEmit",
    "frontend:dev": "vite --config frontend/vite.config.ts",
    "frontend:build": "vite build --config frontend/vite.config.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && npm run frontend:build",
    "test": "node --test test/*.test.ts",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include='src/**/*.ts' --test-coverage-include='bin/**/*.ts' --test-coverage-lines=70 --test-coverage-branches=70 --test-coverage-functions=70 test/*.test.ts",
    "prepublishOnly": "npm run typecheck && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "drizzle-orm": "^1.0.0-rc.4",
    "posthog-node": "^5.41.0",
    "shell-quote": "^1.8.1"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.1",
    "@fortawesome/free-solid-svg-icons": "^7.3.1",
    "@fortawesome/react-fontawesome": "^3.4.0",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/shell-quote": "^1.7.5",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^1.0.0-rc.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.7.0",
    "vite": "^8.1.5"
  }
}
