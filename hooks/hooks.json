{
  "description": "Capture submitted prompts and reconcile them with the active Git branch.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/dist/rudder-prompt-hook.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/dist/rudder-prompt-hook.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
